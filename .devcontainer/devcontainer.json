{
    "name": "Environnement TP n8n",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "devcontainer",
    "workspaceFolder": "/workspaces/bpi-n8n-esnsaas",
    "forwardPorts": [
        "nginx:5678",
        "ollama:11434",
        "qdrant:6333"
    ],
    "portsAttributes": {
        "nginx:5678": {
            "label": "Interface n8n",
            "onAutoForward": "openBrowser",
            "visibility": "public"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        }
    }
}