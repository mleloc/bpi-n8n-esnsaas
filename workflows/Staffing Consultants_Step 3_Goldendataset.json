    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  try {\n    // 1. On extrait la chaîne JSON brute cachée dans la structure de Gemini\n    let rawText = item.json.content.parts[0].text;\n    \n    // 2. Sécurité au cas où Gemini remettrait du markdown plus tard\n    rawText = rawText.replace(/```json|```/g, '').trim();\n    \n    // 3. On transforme cette chaîne en un vrai objet JSON exploitable\n    return JSON.parse(rawText);\n    \n  } catch (error) {\n    // Sécurité atelier : si un item buggue, on ne bloque pas tout le workflow\n    return {\n      \"evaluation\": \"ERROR\",\n      \"raison\": \"Erreur de lecture du Juge : \" + error.message\n    };\n  }\n});"
      },
